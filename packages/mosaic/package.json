{
  "name": "@vantageos/mosaic",
  "version": "0.1.2",
  "description": "Fleet-wide MCP UI design system — 6-category taxonomy, Zod-validated, registry-gated, streaming-ready.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./progress": {
      "import": "./dist/progress.js",
      "require": "./dist/progress.cjs",
      "types": "./dist/progress.d.ts"
    },
    "./input": {
      "import": "./dist/input.js",
      "require": "./dist/input.cjs",
      "types": "./dist/input.d.ts"
    },
    "./display": {
      "import": "./dist/display.js",
      "require": "./dist/display.cjs",
      "types": "./dist/display.d.ts"
    },
    "./artifacts": {
      "import": "./dist/artifacts.js",
      "require": "./dist/artifacts.cjs",
      "types": "./dist/artifacts.d.ts"
    },
    "./confirmation": {
      "import": "./dist/confirmation.js",
      "require": "./dist/confirmation.cjs",
      "types": "./dist/confirmation.d.ts"
    },
    "./media": {
      "import": "./dist/media.js",
      "require": "./dist/media.cjs",
      "types": "./dist/media.d.ts"
    },
    "./server": {
      "import": "./dist/server.js",
      "require": "./dist/server.cjs",
      "types": "./dist/server.d.ts"
    },
    "./registry.yaml": "./registry.yaml"
  },
  "files": [
    "dist",
    "registry.yaml",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "biome check --error-on-warnings src",
    "size-limit": "size-limit",
    "build-storybook": "storybook build -o storybook-static",
    "prepublishOnly": "pnpm run build && pnpm run test && pnpm run size-limit && node scripts/check-eta-gate.js"
  },
  "peerDependencies": {
    "@mcp-ui/client": "7.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "15.5.2",
    "rxjs": "^7.8.0"
  },
  "peerDependenciesMeta": {
    "@mcp-ui/client": {
      "optional": true
    },
    "react-i18next": {
      "optional": true
    },
    "rxjs": {
      "optional": true
    }
  },
  "dependencies": {
    "@lit-labs/react": "1.0.6",
    "@mcp-ui/server": "6.1.0",
    "@tanstack/react-virtual": "3.13.6",
    "dompurify": "3.2.4",
    "marked": "15.0.7",
    "zod": "3.25.28"
  },
  "devDependencies": {
    "@babel/parser": "7.29.7",
    "@babel/traverse": "7.29.7",
    "@types/babel__traverse": "7.28.0",
    "@axe-core/playwright": "4.10.1",
    "@biomejs/biome": "1.9.4",
    "@playwright/test": "1.50.1",
    "@size-limit/preset-small-lib": "11.2.0",
    "@storybook/builder-vite": "8.6.18",
    "@storybook/react": "8.6.18",
    "@storybook/react-vite": "8.6.18",
    "@storybook/test-runner": "0.21.0",
    "@tailwindcss/vite": "4.1.8",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "@types/dompurify": "3.0.5",
    "@types/react": "19.1.0",
    "@types/react-dom": "19.1.0",
    "@vitejs/plugin-react": "4.3.4",
    "@vitest/coverage-v8": "3.2.2",
    "jsdom": "26.0.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "size-limit": "11.2.0",
    "storybook": "8.6.18",
    "tailwindcss": "4.1.8",
    "tsup": "8.4.0",
    "typescript": "5.8.3",
    "vite": "6.3.5",
    "vite-plugin-singlefile": "2.1.0",
    "vitest": "3.2.2"
  }
}
