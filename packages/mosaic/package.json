{
  "name": "@vantageos/mosaic",
  "version": "0.1.0",
  "description": "Fleet-wide MCP UI design system — 6-category taxonomy, Zod-validated, registry-gated, streaming-ready.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "registry.yaml", "README.md"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "biome check --error-on-warnings src",
    "size-limit": "size-limit",
    "prepublishOnly": "pnpm run build && pnpm run test && pnpm run size-limit && node scripts/check-eta-gate.js"
  },
  "peerDependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "15.5.2",
    "@mcp-ui/client": "7.1.1"
  },
  "peerDependenciesMeta": {
    "@mcp-ui/client": { "optional": true },
    "react-i18next": { "optional": true }
  },
  "dependencies": {
    "@lit-labs/react": "1.0.6",
    "@mcp-ui/server": "6.1.0",
    "@tanstack/react-virtual": "3.13.6",
    "recharts": "2.15.3",
    "rxjs": "7.8.2",
    "zod": "3.25.28"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.10.1",
    "@biomejs/biome": "1.9.4",
    "@playwright/test": "1.50.1",
    "@size-limit/preset-small-lib": "11.2.0",
    "@storybook/react": "8.6.12",
    "@storybook/test-runner": "0.21.0",
    "@tailwindcss/vite": "4.1.8",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "19.1.0",
    "@types/react-dom": "19.1.0",
    "@vitejs/plugin-react": "4.3.4",
    "jsdom": "26.0.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "size-limit": "11.2.0",
    "tailwindcss": "4.1.8",
    "tsup": "8.4.0",
    "typescript": "5.8.3",
    "vite": "6.3.5",
    "vite-plugin-singlefile": "2.1.0",
    "vitest": "3.2.2",
    "@vitest/coverage-v8": "3.2.2"
  }
}
