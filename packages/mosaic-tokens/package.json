{
  "name": "@vantageos/mosaic-tokens",
  "version": "0.2.0",
  "description": "Framework-free design tokens (colors, spacing, typography, shadows, radii, motion) for @vantageos/mosaic — CSS custom props + JS exports + Tailwind v4 plugin.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./css": "./src/tokens.css",
    "./tailwind": {
      "types": "./dist/tailwind-plugin.d.ts",
      "import": "./dist/tailwind-plugin.js"
    }
  },
  "files": [
    "dist",
    "src/tokens.css",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "biome check --error-on-warnings src",
    "size-limit": "size-limit"
  },
  "dependencies": {},
  "peerDependencies": {
    "tailwindcss": "^4.1.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@size-limit/preset-small-lib": "11.2.0",
    "@vitest/coverage-v8": "3.2.2",
    "jsdom": "26.0.0",
    "size-limit": "11.2.0",
    "tailwindcss": "4.1.8",
    "tsup": "8.4.0",
    "typescript": "5.8.3",
    "vitest": "3.2.2"
  }
}
