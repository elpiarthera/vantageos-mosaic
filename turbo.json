{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": ["tsconfig.base.json", "biome.json"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "inputs": ["src/**", "tsup.config.ts", "tsconfig.json", "package.json"]
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": ["coverage/**"],
      "inputs": ["src/**", "vitest.config.ts"]
    },
    "lint": {
      "outputs": [],
      "inputs": ["src/**", "biome.json"]
    },
    "size-limit": {
      "dependsOn": ["build"],
      "outputs": [],
      "inputs": ["dist/**", ".size-limit.json"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
